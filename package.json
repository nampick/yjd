{
  "name": "@oix1987/yjd",
  "version": "2.7.6",
  "description": "Dependency-free, tree-shakeable rich text editor & WYSIWYG for the web — with a chat/prompt input layout, bring-your-own-model AI (selection toolbar + ghost-text), @mentions, image/file upload, and HTML/Markdown/JSON export. Ship ~17 KB, not the whole library.",
  "keywords": [
    "rich-text-editor",
    "wysiwyg",
    "wysiwyg-editor",
    "editor",
    "text-editor",
    "contenteditable",
    "html-editor",
    "markdown",
    "tree-shakeable",
    "zero-dependencies",
    "typescript",
    "javascript",
    "react",
    "vue",
    "svelte",
    "prompt-input",
    "chat-input",
    "ai-editor",
    "comment-box"
  ],
  "homepage": "https://yjd.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nampick/yjd.git"
  },
  "bugs": {
    "url": "https://github.com/nampick/yjd/issues"
  },
  "license": "ISC",
  "author": "Oix1987",
  "type": "module",
  "main": "dist/rich-editor.min.js",
  "module": "dist/rich-editor.esm.js",
  "exports": {
    ".": {
      "import": "./dist/rich-editor.esm.js",
      "require": "./dist/rich-editor.min.js"
    },
    "./core": "./core.js",
    "./styles.css": "./lib/styles.min.css",
    "./lib/*": "./lib/*",
    "./package.json": "./package.json"
  },
  "types": "index.d.ts",
  "files": [
    "dist/*.js",
    "lib",
    "core.js",
    "index.js",
    "umd-entry.js",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "generate:css": "node scripts/generate-css.js",
    "prebuild": "npm run generate:css",
    "build": "rollup -c",
    "prepublishOnly": "npm run build",
    "build:demos": "rollup -c demos/rollup.demos.config.js",
    "build:site": "node scripts/build-site.js",
    "build:pages": "npm run build && npm run build:demo-pages && npm run build:compare && node scripts/build-site.js",
    "build:demo-pages": "node scripts/build-demo-pages.js",
    "release": "node scripts/release.mjs",
    "release:gh": "node scripts/gh-release.mjs",
    "size": "size-limit",
    "test:browser": "playwright test",
    "build:compare": "node scripts/build-compare-pages.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@size-limit/file": "^12.1.0",
    "csso": "^5.0.5",
    "jsdom": "^24.1.3",
    "rollup": "^4.46.3",
    "size-limit": "^12.1.0"
  },
  "sideEffects": [
    "./index.js",
    "./umd-entry.js"
  ],
  "size-limit": [
    {
      "name": "ESM (all-in-one)",
      "path": "dist/rich-editor.esm.js",
      "limit": "75 KB"
    },
    {
      "name": "UMD min",
      "path": "dist/rich-editor.min.js",
      "limit": "75 KB"
    },
    {
      "name": "Core ESM",
      "path": "dist/core.esm.js",
      "limit": "75 KB"
    },
    {
      "name": "Stylesheet",
      "path": "lib/styles.min.css",
      "limit": "12 KB"
    }
  ]
}
