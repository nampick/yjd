{
  "name": "@oix1987/yjd",
  "version": "2.5.1",
  "description": "Dependency-free, tree-shakeable rich text editor for the web with a bring-your-own-model AI assistant (selection toolbar + ghost-text), @mentions, image/file upload, and HTML/Markdown/JSON export — ship 17 KB, not the whole library.",
  "keywords": [
    "rich-text-editor",
    "wysiwyg",
    "wysiwyg-editor",
    "editor",
    "text-editor",
    "contenteditable",
    "html-editor",
    "markdown",
    "tree-shakeable",
    "zero-dependencies",
    "typescript",
    "javascript",
    "react",
    "vue",
    "svelte"
  ],
  "homepage": "https://yjd.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nampick/yjd.git"
  },
  "bugs": {
    "url": "https://github.com/nampick/yjd/issues"
  },
  "license": "ISC",
  "author": "Oix1987",
  "type": "module",
  "main": "dist/rich-editor.min.js",
  "module": "dist/rich-editor.esm.js",
  "exports": {
    ".": {
      "import": "./dist/rich-editor.esm.js",
      "require": "./dist/rich-editor.min.js"
    },
    "./core": "./core.js",
    "./styles.css": "./lib/styles.min.css",
    "./lib/*": "./lib/*",
    "./package.json": "./package.json"
  },
  "types": "index.d.ts",
  "files": [
    "dist/*.js",
    "lib",
    "core.js",
    "index.js",
    "umd-entry.js",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "generate:css": "node scripts/generate-css.js",
    "prebuild": "npm run generate:css",
    "build": "rollup -c",
    "prepublishOnly": "npm run build",
    "build:demos": "rollup -c demos/rollup.demos.config.js",
    "build:site": "node scripts/build-site.js",
    "build:pages": "npm run build && node scripts/build-site.js"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "csso": "^5.0.5",
    "jsdom": "^24.1.3",
    "rollup": "^4.46.3"
  },
  "sideEffects": [
    "./index.js",
    "./umd-entry.js"
  ]
}
