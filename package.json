{
  "name": "@oix1987/yjd-vue2",
  "version": "1.0.1",
  "description": "A powerful rich text editor with real-time content change tracking for web applications using vue 2.*",
  "main": "dist/vue2-rich-editor.umd.js",
  "module": "dist/vue2-rich-editor.common.js",
  "unpkg": "dist/vue2-rich-editor.umd.js",
  "jsdelivr": "dist/vue2-rich-editor.umd.js",
  "exports": {
    ".": {
      "import": "./dist/vue2-rich-editor.common.js",
      "require": "./dist/vue2-rich-editor.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "vue-cli-service build --target lib --name vue2-rich-editor src/components/index.js --no-clean",
    "build:lib": "vue-cli-service build --target lib --name vue2-rich-editor src/components/index.js --no-clean",
    "build:clean": "rimraf dist && npm run build",
    "lint": "vue-cli-service lint"
  },
  "keywords": [
    "vue2",
    "rich-editor",
    "text-editor",
    "wysiwyg",
    "component"
  ],
  "author": "Oix1987",
  "license": "ISC",
  "peerDependencies": {
    "vue": "^2.6.0"
  },
  "dependencies": {
    "vue": "^2.6.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/plugin-transform-arrow-functions": "^7.27.1",
    "@babel/plugin-transform-async-generator-functions": "^7.28.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-destructuring": "^7.28.0",
    "@babel/plugin-transform-exponentiation-operator": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.27.1",
    "@babel/plugin-transform-object-rest-spread": "^7.28.0",
    "@babel/plugin-transform-optional-chaining": "^7.27.1",
    "@babel/plugin-transform-parameters": "^7.27.7",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@babel/plugin-transform-private-property-in-object": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/plugin-transform-template-literals": "^7.27.1",
    "@babel/runtime": "^7.28.3",
    "@babel/runtime-corejs3": "^7.28.3",
    "@vue/cli-plugin-babel": "^5.0.8",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "babel-eslint": "^10.1.0",
    "core-js": "^3.45.1",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "rimraf": "^5.0.0",
    "vue-template-compiler": "^2.6.14"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
